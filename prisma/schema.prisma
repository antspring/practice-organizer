generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  admin
}

enum FormFieldType {
  text
  select
}

enum PracticeApplicationStatus {
  pending
  approved
  rejected
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(student)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens        RefreshToken[]
  practiceApplications PracticeApplication[]
  practiceProfile      PracticeProfile?

  @@map("users")
}

model PracticeProfile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  fullName         String?  @map("full_name")
  specialty        String?
  educationProgram String?  @map("education_program")
  group            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("practice_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Cohort {
  id                  String   @id @default(uuid())
  title               String
  description         String?
  publicSlug          String   @unique @map("public_slug")
  startsAt            DateTime @map("starts_at")
  endsAt              DateTime @map("ends_at")
  applicationStartsAt DateTime @map("application_starts_at")
  applicationEndsAt   DateTime @map("application_ends_at")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  formFields           CohortFormField[]
  practiceApplications PracticeApplication[]
  assignment           CohortAssignment?
  tracks               CohortTrack[]

  @@map("cohorts")
}

model CohortTrack {
  id          String   @id @default(uuid())
  cohortId    String   @map("cohort_id")
  title       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cohort               Cohort                @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  practiceApplications PracticeApplication[]

  @@unique([cohortId, title])
  @@index([cohortId])
  @@map("cohort_tracks")
}

model CohortAssignment {
  id          String   @id @default(uuid())
  cohortId    String   @unique @map("cohort_id")
  title       String
  description String?
  content     String
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@map("cohort_assignments")
}

model CohortFormField {
  id         String        @id @default(uuid())
  cohortId   String        @map("cohort_id")
  key        String
  label      String
  type       FormFieldType
  isRequired Boolean       @default(true) @map("is_required")
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  cohort  Cohort                      @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  options CohortFormFieldOption[]
  answers PracticeApplicationAnswer[]

  @@unique([cohortId, key])
  @@index([cohortId])
  @@map("cohort_form_fields")
}

model CohortFormFieldOption {
  id        String   @id @default(uuid())
  fieldId   String   @map("field_id")
  label     String
  value     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  field   CohortFormField             @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  answers PracticeApplicationAnswer[]

  @@unique([fieldId, value])
  @@index([fieldId])
  @@map("cohort_form_field_options")
}

model PracticeApplication {
  id        String                    @id @default(uuid())
  userId    String                    @map("user_id")
  cohortId  String                    @map("cohort_id")
  trackId   String?                   @map("track_id")
  status    PracticeApplicationStatus @default(pending)
  createdAt DateTime                  @default(now()) @map("created_at")
  updatedAt DateTime                  @updatedAt @map("updated_at")

  user    User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort  Cohort                      @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  track   CohortTrack?                @relation(fields: [trackId], references: [id], onDelete: SetNull)
  answers PracticeApplicationAnswer[]
  review  PracticeReview?
  report  PracticeReport?

  @@unique([userId, cohortId])
  @@index([cohortId])
  @@index([trackId])
  @@index([userId])
  @@map("practice_applications")
}

model PracticeReport {
  id            String   @id @default(uuid())
  applicationId String   @unique @map("application_id")
  storageKey    String   @unique @map("storage_key")
  originalName  String   @map("original_name")
  mimeType      String   @map("mime_type")
  size          Int
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application PracticeApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("practice_reports")
}

model PracticeApplicationAnswer {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  fieldId       String   @map("field_id")
  optionId      String?  @map("option_id")
  value         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application PracticeApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  field       CohortFormField        @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  option      CohortFormFieldOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([applicationId, fieldId])
  @@index([applicationId])
  @@index([fieldId])
  @@index([optionId])
  @@map("practice_application_answers")
}

model PracticeReview {
  id                    String   @id @default(uuid())
  applicationId         String   @unique @map("application_id")
  activities            String?
  characteristic        String?
  isEmployed            Boolean? @map("is_employed")
  employmentPosition    String?  @map("employment_position")
  isNextPracticeOffered Boolean? @map("is_next_practice_offered")
  isEmploymentOffered   Boolean? @map("is_employment_offered")
  suggestions           String?
  grade                 String?
  isReady               Boolean  @default(false) @map("is_ready")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  application PracticeApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("practice_reviews")
}
